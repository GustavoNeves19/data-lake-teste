# ════════════════════════════════════════════════════════════════════════════
# Streamlit Secrets — exemplo (renomear para secrets.toml localmente,
# ou colar o conteúdo no painel "Secrets" do Streamlit Community Cloud)
# ════════════════════════════════════════════════════════════════════════════
#
# NUNCA commitar secrets.toml com valores reais — ele está no .gitignore.
# Apenas este arquivo (.example) deve ser versionado, como template.
# ════════════════════════════════════════════════════════════════════════════

# ── BigQuery: cole aqui o JSON do service account (Nevoni produção)
#    Acessar GCP Console → IAM → Service Accounts → "Nevoni Reader" → Keys
[gcp_service_account]
type = "service_account"
project_id = "sapient-metrics-492914-m7"
private_key_id = "PREENCHER"
private_key = """-----BEGIN PRIVATE KEY-----
PREENCHER
-----END PRIVATE KEY-----
"""
client_email = "PREENCHER@sapient-metrics-492914-m7.iam.gserviceaccount.com"
client_id = "PREENCHER"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "PREENCHER"
universe_domain = "googleapis.com"

# ── OpenAI (Oráculo) — opcional. Se vazio, cada user cola sua chave na sidebar.
OPENAI_API_KEY = "sk-PREENCHER"
OPENAI_MODEL   = "gpt-4o-mini"

# ── Acesso restrito ao dashboard (login compartilhado do grupo).
#    Enquanto [auth].password estiver vazio, o dashboard fica ABERTO (sem login).
#    Preencha aqui (local) e no painel Secrets do Streamlit Cloud para ativar o gate.
[auth]
email    = "acesso@nevoni.com.br"
password = "TROQUE_ESTA_SENHA"
