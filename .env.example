# ==============================================================================
# Data Lake Nevoni — variáveis de ambiente (template)
#
# Copie este arquivo para `.env` (que é gitignored) e preencha com os valores
# reais. NUNCA versione o `.env` com segredos — apenas este `.env.example`.
# ==============================================================================

# ── Ambiente / Pipeline ───────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production (controla o formato de log)
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
BATCH_SIZE=50000                 # nº de linhas por lote de carga no BigQuery
MAX_RETRIES=3                    # tentativas por entidade em caso de falha transitória
RETRY_DELAY_SECONDS=5            # espera entre tentativas
QUERY_TIMEOUT_SECONDS=300        # timeout de consulta ao SQL Server (5 min)
LOCK_TIMEOUT_MS=5000             # lock timeout no SQL Server (5 s)

# ── ERP — SQL Server (fonte primária) ─────────────────────────────────────────
SQL_SERVER_DRIVER=ODBC Driver 17 for SQL Server
SQL_SERVER_HOST=                 # host:porta do ERP (ex.: servidor.exemplo.com.br)
SQL_SERVER_PORT=
SQL_SERVER_DATABASE=             # nome do banco do ERP
SQL_SERVER_USER=
SQL_SERVER_PASSWORD=

# ── Data Warehouse — BigQuery ─────────────────────────────────────────────────
BQ_PROJECT_ID=                   # id do projeto GCP de destino
BQ_DATASET=                      # dataset padrão (camadas dm_*/silver_*/gold_*)
BQ_LOCATION=us-east1
# Caminho do JSON de service account com acesso ao BigQuery.
GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/service-account.json

# ── CRM — Pipedrive ───────────────────────────────────────────────────────────
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_BASE_URL=https://api.pipedrive.com/api/v2
PIPEDRIVE_TIMEOUT=30
PIPEDRIVE_PAUSE_SECONDS=0.2

# ── Atendimento — Umbler Talk ─────────────────────────────────────────────────
UMBLER_API_TOKEN=
UMBLER_ORGANIZATION_ID=
UMBLER_BASE_URL=https://app-utalk.umbler.com/api
UMBLER_BQ_DATASET=umbler_raw
UMBLER_TIMEOUT=30
UMBLER_PAUSE_SECONDS=0.3
# UMBLER_MESSAGES_FROM_UTC=      # opcional: data de corte ISO para histórico
# UMBLER_ENDPOINTS_FILE=         # opcional: override do mapa de endpoints

# ── E-mail — Gmail (via service account com delegação) ─────────────────────────
GMAIL_SERVICE_ACCOUNT_FILE=      # JSON da SA com domain-wide delegation
GMAIL_ACCOUNTS=                  # contas a varrer, separadas por vírgula
GMAIL_QUERY=                     # filtro Gmail opcional (ex.: newer_than:90d)
GMAIL_PAGE_SIZE=500
GMAIL_TIMEOUT=30
GMAIL_PAUSE_SECONDS=0.02

# ── Estado da ingestão incremental ────────────────────────────────────────────
OPS_DATASET=ops                  # dataset de controle (watermarks/idempotência)

# ── Oráculo (assistente analítico do dashboard — opcional) ────────────────────
# Sem chave, a página do Oráculo fica desativada; o resto do dashboard funciona.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Nevoni 360 — backend (auth + metas) ───────────────────────────────────────
# Postgres em produção; sem essa variável, cai em SQLite local (dev).
DATABASE_URL=postgresql://usuario:senha@host:5432/nevoni360
# Assina o cookie de sessão (JWT). Sem essa chave, o login não funciona.
JWT_SECRET=
# Cria o admin inicial quando a tabela de usuários está vazia.
ADMIN_EMAIL=admin@nevoni.com.br
ADMIN_PASSWORD=

# ── Exploração de quadros / tarefas (opcional) ────────────────────────────────
# ClickUp — token pessoal começa com "pk_"; header "Authorization: <token>".
CLICKUP_API_TOKEN=
# CLICKUP_CLIENT_ID=
# CLICKUP_CLIENT_SECRET=
# CLICKUP_REDIRECT_URI=https://localhost/callback
# Miro — access token não-expirável; header "Authorization: Bearer <token>".
MIRO_ACCESS_TOKEN=
# MIRO_ORG_ID=
# MIRO_CLIENT_ID=
# MIRO_CLIENT_SECRET=
# MIRO_REDIRECT_URI=https://localhost/callback
